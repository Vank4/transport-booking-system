{
  "info": {
    "_postman_id": "b7c1b4f0-0d6a-4c64-a6f3-3fa0d4f6a8e1",
    "name": "Transport Booking System API",
    "description": "Postman collection for Flight & Train booking system (Auth, Search, Seats, Booking, Vouchers, Admin). Response format follows docs/30-api/api-conventions.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "sessionId", "value": "client-session-id" },
    { "key": "tripType", "value": "flight" },
    { "key": "tripId", "value": "" },
    { "key": "seatId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "voucherId", "value": "" },
    { "key": "airportFromId", "value": "" },
    { "key": "airportToId", "value": "" },
    { "key": "stationFromId", "value": "" },
    { "key": "stationToId", "value": "" },
    { "key": "airlineId", "value": "" },
    { "key": "trainId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"12345678\",\n  \"fullName\": \"Nguyen Van A\",\n  \"phone\": \"0900000000\"\n}"
            }
          }
        },
        {
          "name": "Login (sets accessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"12345678\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van B\",\n  \"phone\": \"0911111111\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "change-password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"12345678\",\n  \"newPassword\": \"newPassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Public Reference Data",
      "item": [
        {
          "name": "Public - Airports",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/public/airports",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", "airports"]
            }
          }
        },
        {
          "name": "Public - Airlines",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/public/airlines",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", "airlines"]
            }
          }
        },
        {
          "name": "Public - Train Stations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/public/train-stations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", "train-stations"]
            }
          }
        },
        {
          "name": "Public - Trains",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/public/trains",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", "trains"]
            }
          }
        }
      ]
    },
    {
      "name": "Search - Flights",
      "item": [
        {
          "name": "Search Flights",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/flights/search?fromId={{airportFromId}}&toId={{airportToId}}&date=2026-05-01&passengers=1&sort=departureTime&order=asc&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "flights", "search"],
              "query": [
                { "key": "fromId", "value": "{{airportFromId}}" },
                { "key": "toId", "value": "{{airportToId}}" },
                { "key": "date", "value": "2026-05-01" },
                { "key": "passengers", "value": "1" },
                { "key": "sort", "value": "departureTime" },
                { "key": "order", "value": "asc" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Flight Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/flights/{{tripId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "flights", "{{tripId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Search - Train Trips",
      "item": [
        {
          "name": "Search Train Trips",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/train-trips/search?fromId={{stationFromId}}&toId={{stationToId}}&date=2026-05-01&passengers=1&sort=departureTime&order=asc&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "train-trips", "search"],
              "query": [
                { "key": "fromId", "value": "{{stationFromId}}" },
                { "key": "toId", "value": "{{stationToId}}" },
                { "key": "date", "value": "2026-05-01" },
                { "key": "passengers", "value": "1" },
                { "key": "sort", "value": "departureTime" },
                { "key": "order", "value": "asc" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Train Trip Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/train-trips/{{tripId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "train-trips", "{{tripId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Seats (Hold/Release/Sync)",
      "item": [
        {
          "name": "Get Seat Map",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/trips/{{tripType}}/{{tripId}}/seats?includeHold=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "trips", "{{tripType}}", "{{tripId}}", "seats"],
              "query": [{ "key": "includeHold", "value": "true" }]
            }
          }
        },
        {
          "name": "Hold Seat",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/seats/hold",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seats", "hold"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"FLIGHT\",\n  \"tripId\": \"{{tripId}}\",\n  \"seatId\": \"{{seatId}}\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            }
          }
        },
        {
          "name": "Release Seat",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/seats/release",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seats", "release"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seatId\": \"{{seatId}}\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            }
          }
        },
        {
          "name": "Hold Seats (Bulk)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/seats/hold-bulk",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seats", "hold-bulk"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"TRAIN\",\n  \"tripId\": \"{{tripId}}\",\n  \"seatIds\": [\"{{seatId}}\"],\n  \"sessionId\": \"{{sessionId}}\"\n}"
            }
          }
        },
        {
          "name": "Release Seats (Bulk)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/seats/release-bulk",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seats", "release-bulk"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seatIds\": [\"{{seatId}}\"],\n  \"sessionId\": \"{{sessionId}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Booking & Payment",
      "item": [
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/me?page=1&limit=10&sort=createdAt&order=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "me"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "createdAt" },
                { "key": "order", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Booking Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "{{bookingId}}"]
            }
          }
        },
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"FLIGHT\",\n  \"tripId\": \"{{tripId}}\",\n  \"seatIds\": [\"{{seatId}}\"],\n  \"passengers\": [\n    { \"name\": \"Nguyen Van A\", \"type\": \"ADULT\" }\n  ],\n  \"voucherCode\": \"SUMMER2026\",\n  \"paymentMethod\": \"VNPAY\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            }
          }
        },
        {
          "name": "Payment Callback (Gateway -> Backend)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/payments/callback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "callback"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"status\": \"SUCCESS\",\n  \"amount\": 1710000,\n  \"transactionId\": \"gateway-tx-id\",\n  \"signature\": \"signed-hash\"\n}"
            }
          }
        },
        {
          "name": "Mock Confirm Payment (Dev)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/payments/mock-confirm",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "mock-confirm"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"status\": \"SUCCESS\"\n}"
            }
          }
        },
        {
          "name": "Get E-ticket",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/ticket",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "{{bookingId}}", "ticket"]
            }
          }
        }
      ]
    },
    {
      "name": "Vouchers",
      "item": [
        {
          "name": "Apply Voucher",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vouchers/apply",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vouchers", "apply"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SUMMER2026\",\n  \"type\": \"FLIGHT\",\n  \"tripId\": \"{{tripId}}\",\n  \"seatIds\": [\"{{seatId}}\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "dashboard"]
            }
          }
        },
        {
          "name": "Admin - List Vouchers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/vouchers?page=1&limit=10&sort=createdAt&order=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "vouchers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "createdAt" },
                { "key": "order", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Admin - Create Voucher",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/vouchers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "vouchers"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SUMMER2026\",\n  \"discountType\": \"PERCENT\",\n  \"discountValue\": 10,\n  \"maxUsage\": 100,\n  \"expiryDate\": \"2026-08-01T00:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Admin - Update Voucher",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/vouchers/{{voucherId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "vouchers", "{{voucherId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"discountValue\": 15,\n  \"maxUsage\": 200\n}"
            }
          }
        },
        {
          "name": "Admin - Delete Voucher",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/vouchers/{{voucherId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "vouchers", "{{voucherId}}"]
            }
          }
        }
      ]
    }
  ]
}
